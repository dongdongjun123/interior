# ==========================================================
# 환경변수 템플릿 — 복사해서 .env 로 사용
#   cp .env.example .env  (그리고 값 채우기)
# ==========================================================

# --- Gemini (model1 평면도 / model2 무드) ---
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (선택) 특징 추출 — 저토큰·저비용 (model2/run_gemini_features.py, 06_gemini_features)
GEMINI_FEATURE_MODEL=gemini-2.5-flash-lite

# (선택) 분석용 모델 — 인테리어 사진에서 공간 구조 추출 (flash 권장, 정확도↑)
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# (선택) 평면도 이미지 생성 모델
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# (선택) 공간추론 thinking 예산(토큰). 클수록 정확·느림. 0=끄기, -1=동적
GEMINI_THINKING_BUDGET=4096

# (선택) 자기교정 패스: 1이면 layout을 사진과 재대조해 수정(API 1회 추가). 0=끄기
GEMINI_LAYOUT_REFINE=1

# --- 네이버 쇼핑 검색 API (backend/app.py 가구 추천) ---
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
